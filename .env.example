# Firebase Configuration
# Obtenha estas chaves no Console do Firebase (Configurações do Projeto)
VITE_API_KEY=
VITE_AUTH_DOMAIN=
VITE_DATABASE_URL=
VITE_PROJECT_ID=
VITE_STORAGE_BUCKET=
VITE_MESSAGING_SENDER_ID=
VITE_APP_ID=

# Google Drive / Google Login Configuration
# Obtenha no Google Cloud Console (Credenciais -> ID do cliente OAuth 2.0)
VITE_GOOGLE_CLIENT_ID=

# Gemini AI Configuration
# Obtenha em https://aistudio.google.com/app/apikey
VITE_GEMINI_API_KEY=

# Ative apenas se o seu proxy (Nginx/Cloudflare) suportar WebSockets no domínio rpgnep.com.br
VITE_ENABLE_HMR=false
